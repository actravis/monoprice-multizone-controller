# Copy to .env (or export these) to override defaults. All are optional.

# Amplifier model profile. Sets zone/source counts, field ranges, and baud.
# Only monoprice-6 (MPR-6ZHMAUT) is hardware-tested; the others are built from
# documented specs and unverified.
#   monoprice-6      Monoprice MPR-6ZHMAUT (10761) / 6-zone   (default)
#   monoprice-8      Monoprice 44518 / 8-zone
#   monoprice-4      Monoprice 44519 / 4-zone
#   monoprice-39261  Monoprice 39261 passive matrix / 6-zone
#   dayton-dax66     Dayton Audio DAX66 / 6-zone
MODEL=monoprice-6

# Serial device path for the USB-RS232 adapter.
#   macOS:   /dev/cu.usbserial-XXXX
#   Linux:   /dev/ttyUSB0
DEVICE=/dev/cu.usbserial-XXXX

# Serial baud rate. Leave unset to use the model profile's default (9600 8N1).
BAUD=9600

# HTTP port for the web UI / JSON API.
PORT=8080

# Number of daisy-chained amps. Clamped to the model profile's max (usually 3).
AMP_COUNT=1

# How often to poll the amp for state, in milliseconds.
POLL_MS=5000

# Minimum gap between serial commands, in milliseconds (paces the 9600-baud link).
CMD_GAP_MS=120

# mDNS hostname: advertises http://<MDNS_NAME>.local so the app is reachable
# by a friendly name. Set to an empty string to disable mDNS entirely.
MDNS_NAME=multizone

# Where the shared config (names, icons, scenes, PIN) is persisted.
# CONFIG_PATH=./config.json
