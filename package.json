{
  "name": "amp-control",
  "version": "1.0.0",
  "description": "LAN web control for Monoprice (and clone) multizone amplifiers over RS-232",
  "license": "MIT",
  "keywords": [
    "monoprice",
    "mpr-6zhmaut",
    "dayton-dax66",
    "multizone",
    "amplifier",
    "rs232",
    "serial",
    "home-automation"
  ],
  "scripts": {
    "probe": "node probe.js",
    "ports": "node server.js --probe",
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "serialport": "^12.0.0",
    "@serialport/parser-readline": "^12.0.0",
    "bonjour-service": "^1.2.1",
    "dotenv": "^16.4.5"
  }
}
